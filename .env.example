FLOWSCOPE_ENVIRONMENT=development
FLOWSCOPE_DEBUG=true
FLOWSCOPE_DEMO_MODE=false
FLOWSCOPE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flowscope_db
FLOWSCOPE_CORS_ORIGINS=http://localhost:3000
FLOWSCOPE_FRONTEND_URL=http://localhost:3000
FLOWSCOPE_UNIVERSE_SIZE=120
FLOWSCOPE_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,ARBUSDT,OPUSDT,INJUSDT,WIFUSDT,PEPEUSDT,TONUSDT
FLOWSCOPE_BOOTSTRAP_FROM_DATABASE=true
FLOWSCOPE_BACKFILL_ENABLED=true
FLOWSCOPE_BACKFILL_PROVIDER=binance
FLOWSCOPE_BACKFILL_LOOKBACK_DAYS=3
FLOWSCOPE_TRADE_EVALUATOR_INTERVAL_SECONDS=180
FLOWSCOPE_AUTO_FILTER_NEGATIVE_EXPECTANCY=true
FLOWSCOPE_EXPECTANCY_BOOST_FACTOR=0.15
FLOWSCOPE_SIGNAL_DECAY_PER_BUCKET=0.08
FLOWSCOPE_SELF_CALIBRATION_ENABLED=true
FLOWSCOPE_CALIBRATION_CONFIDENCE_SCALE=0.2
NEXT_PUBLIC_API_URL=http://localhost:8000
ADMIN_PIN=123456
